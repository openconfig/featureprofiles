# proto-file: github.com/openconfig/kne/proto/topo.proto
# proto-message: Topology
name: "juniper-ncptx-dutdutate"
nodes: {
    name: "dut1"
    vendor: JUNIPER
    model: "ncptx"
    os: "evo"
    config: {
        image: "ncptx:latest"
        config_path: "/home/evo/configdisk"
        config_file: "juniper.conf"
        file: "bx-config.cfg"
        cert: {
            self_signed: {
                cert_name: "grpc-server-cert"
                key_name: "N/A"
                key_size: 4096
            }
        }
        env: {
            key: "CPTX_COSIM"
            value: "BX"
        }
        env: {
            key: "JUNOS_EVOLVED_CONTAINER"
            value: "1"
        }
    }
    interfaces: {
        key: "eth5"
        value: {
          name: "et-0/0/0:0"
        }
    }
    interfaces: {
        key: "eth9"
        value: {
          name: "et-0/0/1:0"
        }
    }
}
nodes: {
    name: "dut2"
    vendor: JUNIPER
    model: "ncptx"
    os: "evo"
    config: {
        image: "ncptx:latest"
        config_path: "/home/evo/configdisk"
        config_file: "juniper.conf"
        file: "bx-config.cfg"
        cert: {
            self_signed: {
                cert_name: "grpc-server-cert"
                key_name: "N/A"
                key_size: 4096
            }
        }
        env: {
            key: "CPTX_COSIM"
            value: "BX"
        }
        env: {
            key: "JUNOS_EVOLVED_CONTAINER"
            value: "1"
        }
    }
    interfaces: {
        key: "eth9"
        value: {
          name: "et-0/0/1:0"
        }
    }
}
nodes: {
    name: "otg"
    vendor: KEYSIGHT
    version: "0.0.1-9999" # Please update this with the local version from ixiatg-configmap.yaml
}
links: {
    a_node: "otg"
    a_int: "eth1"
    z_node: "dut1"
    z_int: "eth5"
}
links: {
    a_node: "dut1"
    a_int: "eth9"
    z_node: "dut2"
    z_int: "eth9"
}

